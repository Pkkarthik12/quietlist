{
  "name": "quietlist",
  "productName": "QuietList",
  "version": "1.0.0",
  "description": "A calm personal todo list desktop app for everyone.",
  "main": "src/main/main.js",
  "author": "LOQ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pkkarthik12/quietlist.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.quietlist.app",
    "productName": "QuietList",
    "files": [
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "directories": {
      "buildResources": "build"
    },
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon.svg",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Pkkarthik12",
      "repo": "quietlist"
    }
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  }
}
